generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String     @id @default(uuid())
  name      String     @unique
  rut       String     @unique
  contact   String
  logoUrl   String?
  type      TenantType @default(CLIENT)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users User[]
  roles Role[]

  @@map("tenants")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  rut         String?
  phone       String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // Auth fields
  passwordHash String
  refreshToken String?
  tokenExpiry  DateTime?

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@index([email])
  @@index([refreshToken])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  name        String
  description String?

  permissions Json // Stores array of permission strings

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  isSystem Boolean @default(false)
  isActive Boolean @default(true)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, tenantId])
  @@map("roles")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userEmail String?
  tenantId  String?
  action    String
  resource  String?
  details   Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  status    String   @default("SUCCESS")

  @@index([tenantId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

enum TenantType {
  CLIENT
  CARRIER
  SHIPPER
  OPERATOR
  ADMIN
}
